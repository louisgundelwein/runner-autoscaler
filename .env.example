# --- Required ---------------------------------------------------------------

# Shared secret for webhook signature verification. Generate one with
# `openssl rand -hex 32` and configure the same value on every repo webhook.
GITHUB_WEBHOOK_SECRET=

# Fine-grained personal access token, scoped to the repos below, with
# repository permissions: "Administration" (read & write, JIT runner
# registration), "Actions" (read, queued-job reconcile), and optionally
# "Commit statuses" + "Issues" (read & write, failure reporting on the repo).
GITHUB_TOKEN=

# Comma-separated allowlist of repositories served by this autoscaler.
GITHUB_REPOS=your-org/your-repo

# Hetzner Cloud API token (project-scoped, read & write).
HCLOUD_TOKEN=

# --- Optional (defaults shown) ----------------------------------------------

# Hetzner server type for runner VMs. cx33 = 4 vCPU / 8 GB shared x64.
# Check GET /v1/server_types for what's current — Hetzner deprecates lines
# over time and creates fail with 422 on deprecated types.
HETZNER_SERVER_TYPE=cx33
HETZNER_IMAGE=ubuntu-24.04
# nbg1 (Nuremberg), fsn1 (Falkenstein) or hel1 (Helsinki).
HETZNER_LOCATION=nbg1
# Optional: name or ID of a Hetzner SSH key, for debugging runner VMs.
HETZNER_SSH_KEY=

# Labels the runners register with; jobs must target a subset of these,
# e.g. `runs-on: [self-hosted, hetzner]`.
RUNNER_LABELS=self-hosted,hetzner

# Maximum number of runner VMs existing at once.
MAX_RUNNERS=3
# Hard cap on VM age; must exceed your longest job. The cleanup sweep deletes
# anything older, no matter what.
MAX_RUNNER_LIFETIME_MINUTES=120
# How often the cleanup + reconcile sweep runs.
CLEANUP_INTERVAL_MINUTES=15

PORT=8080
